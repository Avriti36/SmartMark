generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ───────────────────────────────────────────────────────

model User {
  id          String       @id @default(cuid())
  email       String       @unique
  name        String?
  image       String?
  password    String?      // Hashed — only set for credentials provider
  createdAt   DateTime     @default(now())
  bookmarks   Bookmark[]
  collections Collection[]
  accounts    Account[]
  sessions    Session[]
}

model Collection {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  emoji       String?
  createdAt   DateTime   @default(now())
  bookmarks   Bookmark[]

  @@index([userId])
}

/// Global content cache — one row per unique normalised URL, shared across all users.
/// AI processing happens once per URL; subsequent saves reuse this row.
model ProcessedContent {
  id               String     @id @default(cuid())
  normalisedUrl    String     @unique // Canonical URL form (see normaliseUrl utility)
  platform         String              // youtube | instagram | twitter | web

  // AI-generated — null until processing completes
  title            String?
  summary          String?
  keyTopics        String[]
  category         String?             // AI-assigned default category
  contentType      String?
  searchableContext String?
  authorHandle     String?
  thumbnailUrl     String?             // Permanent S3/R2 URL uploaded once
  embeddingValues  Float[]             // Raw 1536-dim vector stored for cache-hit reuse

  status           String    @default("pending") // pending | processing | done | failed
  errorMessage     String?

  processedAt      DateTime?
  createdAt        DateTime  @default(now())

  bookmarks        Bookmark[]

  @@index([normalisedUrl])
  @@index([status])
}

/// Per-user bookmark — the user's personal relationship to a piece of content.
model Bookmark {
  id                 String           @id @default(cuid())
  userId             String
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId       String?
  collection         Collection?      @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  processedContentId String
  processedContent   ProcessedContent @relation(fields: [processedContentId], references: [id])

  originalUrl        String           // Un-normalised URL as pasted — for display only
  personalNote       String?

  // null = use AI-assigned category from ProcessedContent
  categoryOverride   String?

  // Mirrors ProcessedContent.status; set to 'done' immediately on cache hit
  status             String    @default("processing") // processing | done | failed
  errorMessage       String?

  createdAt          DateTime  @default(now())

  // Pinecone vector ID = bookmark.id — exists when status = 'done'

  @@unique([userId, processedContentId]) // Prevent duplicate saves
  @@index([userId])
  @@index([processedContentId])
  @@index([collectionId])
}
